{
  "manifest_version": 3,
  "name": "E-book List Manager",
  "version": "0.7.0",
  "description": "Kindle、DMM Books、ebookjapanのライブラリを収集・管理し、CSVに出力します。",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "E-book List Manager",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js", "default-rules.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
